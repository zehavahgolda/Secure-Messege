            label: 'Code Quality',
            maxPoints: 25,
            keys: ['type_hints', 'immutable_dc', 'deterministic', 'exceptions', 'config_mgmt']
        },
        testing: {
            label: 'Testing & DevOps',
            maxPoints: 20,
            keys: ['unit_tests', 'integration_tests', 'docker', 'cli', 'pyproject']
        }
    };

    const SECTION_DISPLAY_IDS = {
        architecture: 'arch-score',
        patterns: 'patterns-score',
        code_quality: 'quality-score',
        testing: 'testing-score'
    };

    // ─── Collect slider weights from data-weight attribute ───
    function getSliderWeights() {
        const weights = {};
        document.querySelectorAll('.score-slider').forEach(s => {
            weights[s.dataset.key] = parseInt(s.dataset.weight) || 10;
        });
        return weights;
    }

    // ─── Colour the score display pill ───
    function colorDisplay(el, val) {
        el.classList.remove('low', 'medium', 'high');
        if (val < 40)       el.classList.add('low');
        else if (val < 70)  el.classList.add('medium');
        else                el.classList.add('high');
    }

    // ─── Wire up sliders ───
    document.querySelectorAll('.score-slider').forEach(slider => {
        slider.addEventListener('input', function () {
            const display = this.nextElementSibling;
            display.textContent = this.value;
            colorDisplay(display, parseInt(this.value));
            calculateScores();
        });
    });

    // ─── Wire up bonus selects ───
    document.querySelectorAll('.bonus-select').forEach(sel => {
        sel.addEventListener('change', calculateScores);
    });

    // ─── Main scoring calculation ───
    function calculateScores() {
        const weights = getSliderWeights();
        const sectionTotals = {};

        Object.entries(SECTION_CONFIG).forEach(([sectionId, cfg]) => {
            let earned = 0;
            let maxPossible = 0;

            cfg.keys.forEach(key => {
                const slider = document.querySelector(`.score-slider[data-key="${key}"]`);
                if (!slider) return;
                const sliderVal = parseInt(slider.value) / 100;   // 0–1
                const keyWeight = weights[key] || 10;
                earned += sliderVal * keyWeight;
                maxPossible += keyWeight;
            });

            // Scale earned to section max points
            const sectionScore = maxPossible > 0
                ? Math.round((earned / maxPossible) * cfg.maxPoints)
                : 0;

            sectionTotals[sectionId] = sectionScore;
            const el = document.getElementById(SECTION_DISPLAY_IDS[sectionId]);
            if (el) el.textContent = sectionScore + '/' + cfg.maxPoints;
        });

        // Base score (sum of sections = 100)
        const baseScore = Object.values(sectionTotals).reduce((a, b) => a + b, 0);

        // Bonus
        const bonusGiven    = parseInt(document.getElementById('bonus_review_given').value)    || 0;
        const bonusReceived = parseInt(document.getElementById('bonus_review_received').value) || 0;
        const bonusFrozen   = parseInt(document.getElementById('bonus_frozen').value)          || 0;
        const bonusSeed     = parseInt(document.getElementById('bonus_seed').value)            || 0;
        const bonusDI       = parseInt(document.getElementById('bonus_di').value)              || 0;
        const totalBonus    = bonusGiven + bonusReceived + bonusFrozen + bonusSeed + bonusDI;

        const finalScore = Math.min(115, baseScore + totalBonus);

        document.getElementById('bonus-score').textContent = '+' + totalBonus;
        document.getElementById('final-score').textContent = finalScore;
        document.getElementById('score-bar').style.width = Math.min(100, finalScore) + '%';

        let bonusText = '🎁 Bonus breakdown: ';
        const parts = [];
        if (bonusGiven > 0)    parts.push(`Code Review given: +${bonusGiven}`);
        if (bonusReceived > 0) parts.push(`Code Review received: +${bonusReceived}`);
        if (bonusFrozen > 0)   parts.push(`Frozen dataclasses: +${bonusFrozen}`);
        if (bonusSeed > 0)     parts.push(`Deterministic seed: +${bonusSeed}`);
        if (bonusDI > 0)       parts.push(`DI Container: +${bonusDI}`);
        bonusText += parts.length > 0 ? parts.join(' | ') : 'No bonuses yet';
        document.getElementById('bonus-breakdown').textContent = bonusText;

        return { sectionTotals, baseScore, totalBonus, finalScore };
    }

    // ─── Copy to clipboard ───
    function copyToClipboard() {
        const result = calculateScores();
        const hours = parseInt(document.getElementById('hours_spent').value) || 0;

        const scores = {};
        document.querySelectorAll('.score-slider').forEach(s => {
            scores[s.dataset.key] = parseInt(s.value);
        });

        const crGiven    = document.getElementById('code_review_done').value;
        const crReceived = document.getElementById('code_review_received').value;

        const bonusLabels = {
            bonus_review_given:    'Code Review Given',
            bonus_review_received: 'Code Review Received',
            bonus_frozen:          'Frozen Dataclasses',
            bonus_seed:            'Deterministic Seed',
            bonus_di:              'DI Container'
        };

        let bonusLines = '';
        Object.entries(bonusLabels).forEach(([id, label]) => {
            const val = parseInt(document.getElementById(id).value) || 0;
            if (val > 0) bonusLines += `  ${label}: +${val}\n`;
        });
        if (!bonusLines) bonusLines = '  No bonuses\n';

        const scoreLines = Object.entries(SECTION_CONFIG).map(([sectionId, cfg]) => {
            const sc = result.sectionTotals[sectionId];
            return `  ${cfg.label}: ${sc}/${cfg.maxPoints}`;
        }).join('\n');

        const detailLines = Object.entries(scores).map(([key, val]) => {
            return `  ${key.toUpperCase().replace(/_/g, ' ')}: ${val}/100`;
        }).join('\n');

        const text = `
╔═══════════════════════════════════════════════════════════╗
║   Self-Assessment — PDF Attendance Report Generator
║   Python | Design Patterns | DevOps
╚═══════════════════════════════════════════════════════════╝

📊 Category Scores (out of 100):
───────────────────────────────────────────────────────────
${scoreLines}

📦 Detailed Scores (slider 0–100 per criterion):
───────────────────────────────────────────────────────────
${detailLines}

🎁 Bonuses:
───────────────────────────────────────────────────────────
${bonusLines}
──── Base Score:  ${result.baseScore}/100
──── Bonuses:     +${result.totalBonus}
🏆 FINAL SCORE:  ${result.finalScore}/115

🤝 Code Review:
───────────────────────────────────────────────────────────
  Review given:     ${crGiven}
  Review received:  ${crReceived}

⏱️  Work hours: ${hours} hours

📝 Notes:
───────────────────────────────────────────────────────────
Architecture:
${document.getElementById('arch_notes').value || '(no notes)'}

Design Patterns:
${document.getElementById('patterns_notes').value || '(no notes)'}

Code Quality:
${document.getElementById('code_quality_notes').value || '(no notes)'}

Testing & DevOps:
${document.getElementById('testing_notes').value || '(no notes)'}

Unified Model:
${document.getElementById('unified_model_notes').value || '(no notes)'}

Code Review Given:
${document.getElementById('your_feedback').value || '(none)'}

Code Review Received:
${document.getElementById('peer_feedback').value || '(none)'}

╔═══════════════════════════════════════════════════════════╗
Submission date: ${new Date().toLocaleString('en-US')}
╚═══════════════════════════════════════════════════════════╝
        `.trim();

        navigator.clipboard.writeText(text).then(() => {
            const n = document.getElementById('copyNotification');
            n.style.display = 'block';
            setTimeout(() => { n.style.display = 'none'; }, 2800);
        }).catch(err => alert('Copy error: ' + err));
    }

    // ─── Reset ───
    function resetForm() {
        if (!confirm('Reset the entire form?')) return;
        document.querySelectorAll('.score-slider').forEach(s => {
            s.value = 50;
            const d = s.nextElementSibling;
            d.textContent = '50';
            colorDisplay(d, 50);
        });
        document.querySelectorAll('textarea').forEach(t => t.value = '');
        document.getElementById('hours_spent').value = '40';
        document.getElementById('code_review_done').value = 'no';
        document.getElementById('code_review_received').value = 'no';
        ['bonus_review_given','bonus_review_received','bonus_frozen','bonus_seed','bonus_di']
            .forEach(id => document.getElementById(id).value = '0');
        calculateScores();
    }

    // ─── Init ───
    window.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.score-slider').forEach(s => {
            colorDisplay(s.nextElementSibling, parseInt(s.value));
        });
        calculateScores();
    });
</script>
</body>
</html>
